        "columna = 'consumo_electrodomesticos'\n",
        "\n",
        "# Crear copias imputadas\n",
        "lineal = datos.copy()\n",
        "lineal[columna] = lineal[columna].interpolate(method='linear')\n",
        "\n",
        "cuadratica = datos.copy()\n",
        "try:\n",
        "    cuadratica[columna] = cuadratica[columna].interpolate(method='quadratic')\n",
        "except:\n",
        "    print(\"No fue posible realizar la interpolación cuadrática en todo el conjunto.\")\n",
        "    cuadratica = None\n",
        "\n",
        "ffill = datos.copy()\n",
        "ffill[columna] = ffill[columna].ffill()\n",
        "\n",
        "bfill = datos.copy()\n",
        "bfill[columna] = bfill[columna].bfill()\n",
        "\n",
        "# Ventanas de interés\n",
        "ventanas = [\n",
        "    ('2016-02-13 19:30', '2016-02-13 21:00'),\n",
        "    ('2016-02-18 10:00', '2016-02-18 14:30'),\n",
        "    ('2016-03-03 16:30', '2016-03-03 19:00'),\n",
        "    ('2016-03-08 19:00', '2016-03-08 20:30'),\n",
        "    ('2016-03-15 15:30', '2016-03-15 17:30'),\n",
        "    ('2016-04-13 11:00', '2016-04-13 12:30')\n",
        "]\n",
        "\n",
        "for inicio, fin in ventanas:\n",
        "\n",
        "    plt.figure(figsize=(12, 5))\n",
        "\n",
        "    # Datos originales\n",
        "    plt.plot(\n",
        "        datos.loc[inicio:fin].index,\n",
        "        datos.loc[inicio:fin, columna],\n",
        "        'ko',\n",
        "        markersize=5,\n",
        "        label='Original'\n",
        "    )\n",
        "\n",
        "    # Métodos\n",
        "    plt.plot(\n",
        "        lineal.loc[inicio:fin].index,\n",
        "        lineal.loc[inicio:fin, columna],\n",
        "        label='Interpolación lineal'\n",
        "    )\n",
        "\n",
        "    if cuadratica is not None:\n",
        "        plt.plot(\n",
        "            cuadratica.loc[inicio:fin].index,\n",
        "            cuadratica.loc[inicio:fin, columna],\n",
        "            label='Interpolación cuadrática'\n",
        "        )\n",
        "\n",
        "    plt.plot(\n",
        "        ffill.loc[inicio:fin].index,\n",
        "        ffill.loc[inicio:fin, columna],\n",
        "        label='Forward Fill'\n",
        "    )\n",
        "\n",
        "    plt.plot(\n",
        "        bfill.loc[inicio:fin].index,\n",
        "        bfill.loc[inicio:fin, columna],\n",
        "        label='Backward Fill'\n",
        "    )\n",
        "\n",
        "    plt.title(f'Comparación de imputación: {inicio} a {fin}')\n",
        "    plt.xlabel('Hora')\n",
        "    plt.ylabel('Consumo eléctrico')\n",
        "    plt.legend()\n",
        "    plt.grid(True)\n",
        "    plt.tight_layout()\n",
        "    plt.show()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "jZJ40SBPFTb9"
      },
      "source": [
        "Se compararon interpolaciones lineales y cuadráticas sobre los bloques de observaciones faltantes. Aunque ambos métodos produjeron resultados similares en los bloques pequeños, en el bloque más extenso la interpolación cuadrática generó una trayectoria más pronunciada, la cual no se ajusta a la forma observada. Por ello, se optó por la interpolación lineal, ya que proporciona una transición más conservadora entre observaciones consecutivas y reduce el riesgo de introducir patrones artificiales en la serie temporal."
      ]
