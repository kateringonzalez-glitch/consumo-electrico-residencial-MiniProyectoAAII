        "# Calculamos la media móvil de 24 horas.\n",
        "datos_horarios[\"media_movil_24\"] = (\n",
        "    datos_horarios[\"consumo_electrodomesticos\"]\n",
        "    .rolling(window=24)\n",
        "    .mean()\n",
        ")\n",
        "\n",
        "# Creamos una variable numérica que representa el paso del tiempo.\n",
        "# Cada hora recibe un número consecutivo: 0, 1, 2, 3, ...\n",
        "tiempo = np.arange(len(datos_horarios))\n",
        "# Ajustamos una recta de tendencia sobre la variable objetivo.\n",
        "# polyfit con grado 1 ajusta una función lineal: y = a*x + b.\n",
        "coeficientes = np.polyfit(\n",
        "    tiempo,\n",
        "    datos_horarios[\"consumo_electrodomesticos\"],\n",
        "    deg=1\n",
        ")\n",
        "# Calculamos los valores de la tendencia lineal para cada hora.\n",
        "datos_horarios[\"tendencia_lineal\"] = np.polyval(coeficientes, tiempo)\n",
        "\n",
        "# Mostramos las primeras filas para verificar las nuevas columnas.\n",
        "datos_horarios.head()"
